# Variáveis injetadas pelo user-data via fetch_ssm (puxa SSM /cpt/prod/* e
# grava em /opt/cpt/.env, modo 0600 root). Este arquivo serve como referência
# de quais nomes existem — NUNCA preencha valores reais e nunca commite o .env real.

# Domínio + Caddy
DOMAIN=cpt.bet

# Imagens GHCR (atualizadas pelo Watchtower seguindo a tag)
CPT_IMAGE=ghcr.io/klevison/cpt:latest
PUBLISHER_IMAGE=ghcr.io/klevison/wh-publisher:latest

# Phoenix
DATABASE_URL=ecto://cpt:CHANGE_ME@postgres:5432/cpt
SECRET_KEY_BASE=CHANGE_ME
INTERNAL_TOKEN=CHANGE_ME
PHX_HOST=cpt.bet
REDIS_URL=redis://redis:6379/0

# Postgres
POSTGRES_PASSWORD=CHANGE_ME

# Backups + AWS
S3_BACKUPS_BUCKET=cpt-backups-XXXXXXXX
AWS_REGION=eu-west-2

# GHCR auth (usado pelo docker login no boot e pelo Watchtower via /root/.docker/config.json)
GHCR_USER=klevison
GHCR_TOKEN=ghp_CHANGE_ME
