# Caddy em modo HTTP-only (bootstrap MVP sem dominio).
# Quando registrar dominio em Route 53 e ativar enable_route53, trocar `:80`
# por `{$DOMAIN}` para reabilitar TLS automatico Let's Encrypt.
#
# WebSocket LiveView funciona em reverse_proxy direto (Caddy detecta Upgrade).
# Phoenix em prod aplica Plug.RewriteOn nesses headers.

:80 {
    encode gzip zstd

    reverse_proxy phoenix:4000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For   {remote_host}
        header_up Host              {host}
    }

    log {
        output stdout
        format console
    }
}
